{
  "data": {
    "dqn_policy": { "file": "data/dqn_policy.parquet" }
  },
  "params": { "selDqn": { "select": "single" } },
  "vconcat": [
    { "input": "menu", "from": "dqn_policy", "column": "run_id", "label": "Run", "as": "$selDqn" },
    {
      "plot": [
        {
          "mark": "rectY",
          "data": { "from": "dqn_policy", "filterBy": "$selDqn" },
          "x": { "bin": "alpha" },
          "y": { "count": true },
          "fill": "steelblue",
          "insetLeft": 0.5,
          "insetRight": 0.5
        }
      ],
      "width": 500, "height": 280,
      "xLabel": "Alpha (GAT weight in fusion)",
      "yLabel": "Count"
    }
  ]
}
