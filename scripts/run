#!/usr/bin/env bash
# Single SLURM submitter. Two modes:
#
#   1. Training (preset-oriented) — the common path:
#        scripts/run <preset.jsonnet> [--dataset X --seed N --scale s
#            --cluster c --smoke --cpu --ckpt PATH --vgae-ckpt PATH
#            --gat-ckpt PATH --lake-root PATH --set KEY=VAL --mem M
#            --time T --time-from-history --dry-run]
#
#   2. Ops (generic command) — everything that's not `graphids fit`:
#        scripts/run --command "python -m graphids rebuild-caches --all" \
#            --mode cpu --mem 54G --time 4:00:00
#        scripts/run --command "python -m pytest" --mode cpu --length short
#        scripts/run --command "python -m graphids test --config X --ckpt Y" --mode cpu
#
# Profile is a single-word selector — `gpu` or `cpu` — from
# configs/resources/submit_profiles.json. Per-job specifics (cpus, mem, time,
# command) are args, never new JSON entries.
#
# Env:
#   SBATCH_DEP=afterok:<jid>   chain this job behind another
#   MLFLOW_PARENT_RUN_ID=<id>  link this run under a parent MLflow run
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_ROOT"
source .env

command -v jsonnet >/dev/null 2>&1 || {
    echo "scripts/run: jsonnet binary not found on PATH." >&2
    echo "  Install go-jsonnet 0.20.0+ to ~/.local/bin/ — see ADR 0010." >&2
    exit 1
}

PROFILES_JSON="$PROJECT_ROOT/configs/resources/submit_profiles.json"

# -- Arg parsing -------------------------------------------------------------
PRESET=""
COMMAND=""
MODE=""                 # gpu | cpu (default: gpu for preset, required for --command)
LENGTH="long"           # short | long
CLUSTER="${GRAPHIDS_CLUSTER:-pitzer}"
DATASET=""
SCALE=""
GROUP=""
MEM_OVERRIDE=""
TIME_OVERRIDE=""
TIME_FROM_HISTORY=""
DRY_RUN=""
TLAS=()
SETS=()

_push_str_tla() { TLAS+=(--tla "$1=\"$2\""); }
_push_int_tla() { TLAS+=(--tla "$1=$2"); }

# First positional (if present and not starting with --) is a preset path.
if [[ $# -gt 0 && "$1" != --* ]]; then
    PRESET="$1"
    shift
    [[ -f "$PRESET" ]] || { echo "scripts/run: preset not found: $PRESET" >&2; exit 2; }
    GROUP="$(basename "$(dirname "$PRESET")")"
fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --command)                    COMMAND="$2";                        shift 2 ;;
        --mode)                       MODE="$2";                           shift 2 ;;
        --length)                     LENGTH="$2";                         shift 2 ;;
        --cluster)                    CLUSTER="$2";                        shift 2 ;;
        --mem)                        MEM_OVERRIDE="$2";                   shift 2 ;;
        --time)                       TIME_OVERRIDE="$2";                  shift 2 ;;
        --time-from-history)          TIME_FROM_HISTORY=1;                 shift ;;
        --smoke)                      LENGTH="short";                      shift ;;
        --cpu)                        MODE="cpu";                          shift ;;
        --dataset)  DATASET="$2";     _push_str_tla dataset        "$2";   shift 2 ;;
        --seed)                       _push_int_tla seed           "$2";   shift 2 ;;
        --scale)    SCALE="$2";       _push_str_tla scale          "$2";   shift 2 ;;
        --ckpt)                       _push_str_tla ckpt_path      "$2";   shift 2 ;;
        --vgae-ckpt)                  _push_str_tla vgae_ckpt_path "$2";   shift 2 ;;
        --gat-ckpt)                   _push_str_tla gat_ckpt_path  "$2";   shift 2 ;;
        --lake-root)                  _push_str_tla lake_root      "$2";   shift 2 ;;
        --set)                        SETS+=(--set "$2");                  shift 2 ;;
        --dry-run)                    DRY_RUN=1;                           shift ;;
        *) echo "scripts/run: unknown arg: $1" >&2; exit 2 ;;
    esac
done

# Preset path implies fit command + gpu mode by default.
if [[ -n "$PRESET" && -z "$COMMAND" ]]; then
    INNER="python -m graphids fit --config $PRESET"
    for t in ${TLAS[@]+"${TLAS[@]}"}; do INNER+=" $(printf '%q' "$t")"; done
    for s in ${SETS[@]+"${SETS[@]}"}; do INNER+=" $(printf '%q' "$s")"; done
    COMMAND="$INNER"
    [[ -z "$MODE" ]] && MODE="gpu"
    JOBNAME="graphids-$(basename "$PRESET" .jsonnet)"
elif [[ -n "$COMMAND" ]]; then
    [[ -z "$MODE" ]] && { echo "scripts/run: --command requires --mode gpu|cpu" >&2; exit 2; }
    # Derive a job name from the first "meaningful" word after "python -m graphids".
    JOBNAME="graphids-$(echo "$COMMAND" | awk '{for(i=1;i<=NF;i++) if ($i ~ /^[a-z]/ && $i != "python" && $i != "graphids" && $i != "-m") {print $i; exit}}')"
    [[ -z "$JOBNAME" || "$JOBNAME" == "graphids-" ]] && JOBNAME="graphids-cmd"
else
    echo "scripts/run: need either <preset.jsonnet> or --command \"...\"" >&2
    exit 2
fi

# -- Read the profile --------------------------------------------------------
PROFILE_JSON=$(python - <<PY
import json, sys
profiles = json.load(open("$PROFILES_JSON"))["submit_profiles"]
p = profiles["$MODE"]
partition = p["partitions"]["$CLUSTER"]["$LENGTH"]
time_default = p["times"]["$CLUSTER"]["$LENGTH"]
print(f"{partition}|{p['cpus']}|{p['mem']}|{time_default}|{p.get('signal') or 'NONE'}")
PY
)
IFS='|' read -r PARTITION CPUS MEM TIME SIGNAL <<< "$PROFILE_JSON"

# Apply overrides.
[[ -n "$MEM_OVERRIDE" ]] && MEM="$MEM_OVERRIDE"
[[ -n "$TIME_OVERRIDE" ]] && TIME="$TIME_OVERRIDE"

# Optional MLflow walltime estimation (fit-only, requires group + dataset).
if [[ -n "$TIME_FROM_HISTORY" && -z "$TIME_OVERRIDE" && -n "$GROUP" && -n "$DATASET" && "$LENGTH" == "long" ]]; then
    EST=$(python - <<PY
from graphids.slurm.sizing import estimate_walltime_minutes, format_hms
mins = estimate_walltime_minutes("$CLUSTER", "$GROUP", "$DATASET")
print(format_hms(mins) if mins else "")
PY
)
    [[ -n "$EST" ]] && TIME="$EST"
fi

# -- Build the sbatch invocation --------------------------------------------
SLURM_LOG_DIR="${GRAPHIDS_SLURM_LOG_DIR:-${GRAPHIDS_LAKE_ROOT:-experimentruns}/slurm}"
mkdir -p "$SLURM_LOG_DIR"

PREAMBLE="source ${SCRIPT_DIR}/slurm/_preamble.sh"
ENV=""
[[ "$MODE" == "cpu" ]] && ENV="SKIP_CUDA_CONF=1 "

SBATCH=(sbatch
    --account="${GRAPHIDS_SLURM_ACCOUNT}"
    --partition="$PARTITION"
    --cpus-per-task="$CPUS"
    --mem="$MEM"
    --time="$TIME"
    --job-name="$JOBNAME"
    --output="${SLURM_LOG_DIR}/${JOBNAME}_%j.out"
    --error="${SLURM_LOG_DIR}/${JOBNAME}_%j.err"
    --clusters="$CLUSTER"
)
[[ "$MODE" == "gpu" ]] && SBATCH+=(--gres="gpu:1")
[[ -n "$SIGNAL" && "$SIGNAL" != "NONE" ]] && SBATCH+=(--signal="B:${SIGNAL}")
[[ -n "${SBATCH_DEP:-}" ]] && SBATCH+=(--dependency="$SBATCH_DEP")

WRAP="${ENV}${PREAMBLE} && ${COMMAND}"

if [[ -n "$DRY_RUN" ]]; then
    printf '%q ' "${SBATCH[@]}"
    printf -- '--wrap=%q\n' "$WRAP"
    exit 0
fi

"${SBATCH[@]}" --wrap="$WRAP"
