{
  "_comment": "Static profiles have fixed time/mem. Profiles with a 'scaling' block auto-size from cache_metadata.json.aggregate.num_raw_samples; 'defaults' is the fallback when --dataset is not provided.",
  "submit_profiles": {
    "tests": {
      "partition": "cpu",
      "cpus": 8,
      "mem": "16G",
      "time": "1:00:00",
      "signal": "",
      "mode": "cpu",
      "command": "python -m pytest"
    },
    "rebuild-caches": {
      "partition": "cpu",
      "cpus": 6,
      "signal": "",
      "mode": "cpu",
      "command": "python -m graphids rebuild-caches",
      "scaling": {
        "time_min": {"base": 2.0, "per_mraw": 0.083},
        "mem_gb":   {"base": 5.0, "per_mraw": 0.61}
      },
      "defaults": {"time": "1:00:00", "mem": "54G"}
    },
    "profile": {
      "partition": "gpudebug",
      "cpus": 4,
      "mem": "36G",
      "time": "1:00:00",
      "signal": "",
      "mode": "gpu",
      "command": "python -m graphids profile"
    },
    "analyze": {
      "partition": "gpu",
      "cpus": 4,
      "mem": "32G",
      "time": "2:00:00",
      "signal": "",
      "mode": "gpu",
      "command": "python -m graphids analyze"
    },
    "fit": {
      "partitions": {
        "pitzer":   {"short": "gpudebug", "long": "gpu"},
        "cardinal": {"short": "debug",    "long": "gpu"},
        "ascend":   {"short": "debug",    "long": "gpu"}
      },
      "cpus": 8,
      "mem": "48G",
      "time_short": "1:00:00",
      "time_long":  "4:00:00",
      "signal": "",
      "mode": "gpu",
      "command": "python -m graphids fit"
    },
    "fit-cpu": {
      "partitions": {
        "pitzer":   {"short": "debug-cpu", "long": "cpu"},
        "cardinal": {"short": "debug",     "long": "cpu"},
        "ascend":   {"short": "debug",     "long": "cpu"}
      },
      "cpus": 16,
      "mem": "32G",
      "time_short": "1:00:00",
      "time_long":  "4:00:00",
      "signal": "",
      "mode": "cpu",
      "command": "python -m graphids fit"
    },
    "extract-fusion-states": {
      "partition": "gpu",
      "cpus": 4,
      "mem": "36G",
      "time": "0:30:00",
      "signal": "",
      "mode": "gpu",
      "command": "python -m graphids extract-fusion-states"
    }
  }
}
