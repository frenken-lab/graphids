{
  "stages": {
    "autoencoder": {
      "learning_type": "unsupervised",
      "family": "unsupervised",
      "mode": "gpu_train",
      "depends_on": [],
      "identity_keys": ["scale", "conv_type", "variational", "model_type"]
    },
    "supervised": {
      "learning_type": "supervised",
