        {"family": "supervised", "stage": "supervised"}
      ],
      "identity_keys": ["scale", "loss_fn", "method", "conv_type"]
    }
  },
  "default_stages": ["autoencoder", "supervised", "fusion"],
  "ckpt_stages": {
    "vgae": "autoencoder",
    "dgi": "autoencoder",
