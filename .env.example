# KD-GAT project overrides (copy to .env and customize)
# Secrets (GH_TOKEN, R2 creds, AWS creds) go in ~/.env.local — see dotfiles repo

# S3 bucket for lakehouse + DVC
export KD_GAT_S3_BUCKET="kd-gat"

# SLURM settings
export KD_GAT_SLURM_ACCOUNT="PAS1266"
export KD_GAT_SLURM_PARTITION="gpu"
export KD_GAT_GPU_TYPE="v100"

# Scratch filesystem (90-day purge)
export KD_GAT_SCRATCH="/fs/scratch/PAS1266"

# Python command (use "python" — OSC module system provides it)
export KD_GAT_PYTHON="python"

# Shared project storage — all PAS1266 members can read/query.
# Phase 1: scratch (swap to /fs/ess/PAS1266/kd-gat when ESS is provisioned)
# export KD_GAT_SHARED_ROOT="/fs/scratch/PAS1266/kd-gat-shared"

# Data storage root (raw CSVs, graph cache, datalake Parquet)
# export KD_GAT_DATA_ROOT="${KD_GAT_SHARED_ROOT}/data"

# Experiment runs root (model checkpoints, configs, metrics)
# export KD_GAT_EXPERIMENT_ROOT="${KD_GAT_SHARED_ROOT}/experimentruns"

# Cache root override (defaults to $KD_GAT_DATA_ROOT/cache if unset)
# export KD_GAT_CACHE_ROOT="/fs/scratch/PAS1266/kd-gat-cache"
