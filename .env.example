# GraphIDS project overrides (copy to .env and customize)
# Secrets (GH_TOKEN, R2 creds, AWS creds) go in ~/.env.local — see dotfiles repo

# SLURM settings
export GRAPHIDS_SLURM_ACCOUNT="PAS1266"
export GRAPHIDS_SLURM_PARTITION="gpu"
export GRAPHIDS_GPU_TYPE="v100"

# Scratch filesystem (90-day purge)
export GRAPHIDS_SCRATCH="/fs/scratch/PAS1266"

# Python command (use "python" — OSC module system provides it)
export GRAPHIDS_PYTHON="python"

# Shared project storage — all PAS1266 members can read/query.
# Phase 1: scratch (swap to /fs/ess/PAS1266/graphids when ESS is provisioned)
# export GRAPHIDS_SHARED_ROOT="/fs/scratch/PAS1266/graphids-shared"

# Data storage root (raw CSVs, graph cache)
# export GRAPHIDS_DATA_ROOT="${GRAPHIDS_SHARED_ROOT}/data"

# Experiment runs root (model checkpoints, configs, metrics)
# export GRAPHIDS_EXPERIMENT_ROOT="${GRAPHIDS_SHARED_ROOT}/experimentruns"

# Cache root override (defaults to $GRAPHIDS_DATA_ROOT/cache if unset)
# export GRAPHIDS_CACHE_ROOT="/fs/scratch/PAS1266/graphids-cache"
